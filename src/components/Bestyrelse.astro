---
const { navn, beskrivelse, image, stilling, link} = Astro.props;
import Titel from "./Titel.astro";
---

<li>
    <a href={"/produkter/"+link}>
        <Titel>{stilling}</Titel>
        <img src={`/../bestyrelse/${image}`} alt="">
        <h3>{navn}</h3>
        <p>{beskrivelse}</p>
    </a>
</li>

<style>
        a{
        color:var(--black-primary02);
        font-weight:400;
        font-style: normal;
    }
    h3:nth-of-type(2){
        max-width: 28ch;
        color:var(--white-primary01);
    }
    p{
        max-width: 30ch;
        color:var(--white-primary01);
    }
    img{
        width:90%;
        padding-bottom: 1rem;
    }
</style>