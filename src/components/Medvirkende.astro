---
const {navn, stilling, image} = Astro.props;
import Titel from "./Titel.astro";
---

<li>
    <Titel>{stilling}</Titel>
    <img src={`/../vaerk/${image}`} alt="">
</li>
<li>
    <h3>{navn}</h3>
</li>

<style>
    li{
        align-items: center;
        justify-content: center;
    }
    h3{
        color:var(--white-primary01);
    }
</style>