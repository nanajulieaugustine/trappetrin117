---
import Layout from "../layouts/Layout.astro";
import VaerkScrolling from "../components/Vaerk_scrolling.astro";
const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlpamNkZXF1dGNreGFsanZ2Z2loIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI1NjM4OTgsImV4cCI6MjA1ODEzOTg5OH0.F4NYK0yQa7OpLi5q47PgDg5tU0tn6G5btG9VgPnfKzo";

const vaerker = await fetch(`https://yijcdequtckxaljvvgih.supabase.co/rest/v1/vaerker`, {
  method: "GET",
  headers: {
    apikey: key,
  },
}).then((response) => response.json());
const aktive_vaerker = vaerker.slice(0,1)
---
<Layout>
    {aktive_vaerker.map((aktive_vaerker)=>(
      <VaerkScrolling image={aktive_vaerker.image} genre={aktive_vaerker.genre} beskrivelse={aktive_vaerker.beskrivelse} titel={aktive_vaerker.titel} spilledatoer={aktive_vaerker.spilledatoer} link={aktive_vaerker.id}>aktuelle værker</VaerkScrolling>
      ))
    }
</Layout>